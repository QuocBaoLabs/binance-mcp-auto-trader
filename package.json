{
  "name": "binance-mcp-auto-trader",
  "version": "0.1.0",
  "description": "Local-first Binance USD-M Futures trading workstation with MCP tools, React dashboard, SQLite state, and guarded automation.",
  "private": false,
  "type": "module",
  "keywords": [
    "binance",
    "futures",
    "mcp",
    "auto-trading",
    "typescript",
    "react",
    "sqlite"
  ],
  "scripts": {
    "dev": "concurrently -n API,DASH -c cyan,green \"npm run dev:api\" \"npm run dev:dashboard\"",
    "dev:api": "tsx watch server/src/http.ts",
    "dev:dashboard": "vite --host 127.0.0.1",
    "dev:mcp": "tsx server/src/mcp/server.ts",
    "build": "npm run build:server && vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "start": "node dist/server/http.js",
    "mcp": "node dist/server/mcp/server.js",
    "typecheck": "tsc -p tsconfig.server.json --noEmit && tsc -p tsconfig.dashboard.json --noEmit",
    "test": "node --import tsx --test server/src/**/*.test.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@vitejs/plugin-react": "^5.1.1",
    "animejs": "^4.4.1",
    "better-sqlite3": "^12.10.0",
    "concurrently": "^9.2.1",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "lightweight-charts": "^5.2.0",
    "lucide-react": "^0.562.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "three": "^0.184.0",
    "vite": "^8.0.14",
    "ws": "^8.18.3",
    "zod": "^4.2.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.0.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
