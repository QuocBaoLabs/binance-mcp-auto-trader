# Keep credentials on the backend only. Never expose raw keys to the dashboard.
BINANCE_API_KEY=
BINANCE_API_SECRET=

# Safe defaults
READ_ONLY=true
AUTO_TRADE_ENABLED=false
DRY_RUN=true
BINANCE_TESTNET=true
ALLOW_MARKET_ORDER=false
ENABLE_LIVE_TRADING=false
TRADINGVIEW_WEBHOOK_SECRET=
TRADINGVIEW_AUTO_EXECUTE=false

# Binance USD-M Futures REST hosts
BINANCE_LIVE_BASE_URL=https://fapi.binance.com
BINANCE_TESTNET_BASE_URL=https://demo-fapi.binance.com

# Symbols and risk limits
ALLOWED_SYMBOLS=BTCUSDT,ETHUSDT
MAX_ORDER_USDT=25
MAX_DAILY_LOSS_USDT=50
MAX_OPEN_POSITIONS=1
MAX_LEVERAGE=1
TP_PERCENT=1.5
SL_PERCENT=0.8
MIN_CONFIDENCE=70
STRATEGY_INTERVAL_SECONDS=30
KLINE_INTERVAL=5m

# Swing Failure Pattern strategy
SFP_ENABLED=true
SFP_LEN=5
RULE_SFP_SIGNAL=false
SFP_STRATEGIES=sfp
SFP_TIMEFRAMES=5m
SFP_LEVERAGE=1
SFP_MARGIN_USDT=10
SFP_TP_PERCENT=0
SFP_CANDLESTICK_TP_PERCENT=0.5
SFP_MARGIN_TYPE=CROSSED
SFP_AUTO_EXECUTE=false
SFP_WAIT_CANDLES=3
SFP_ONE_TRADE_AT_A_TIME=true
SFP_USE_TRAILING_STOP=false
SFP_TRAILING_CALLBACK_RATE=1.5
SFP_TRAILING_ACTIVATION_PCT=0.5

# Rule engine
STRATEGY_MODE=rules
TOUCH_TOLERANCE_PERCENT=0.15
RULE_SUPERTREND_EMA10_LONG=true
RULE_SUPERTREND_EMA10_SHORT=true
RULE_REQUIRE_TREND_DIRECTION=true
RULE_REQUIRE_EMA10_TOUCH=true
RULE_REQUIRE_SUPERTREND_TOUCH=true
RULE_BOLLINGER_REVERSION=false

# Wyckoff Accumulation / Distribution
WYCKOFF_RSI_LENGTH=14
WYCKOFF_TREND_SENSITIVITY=20
WYCKOFF_PIVOT_LENGTH=5
WYCKOFF_USE_VOLUME_FILTER=true
WYCKOFF_VOLUME_MA_LENGTH=20
WYCKOFF_BREAKOUT_BUFFER_PCT=0.1
WYCKOFF_RETEST_TOLERANCE_PCT=0.2
WYCKOFF_MAX_RISK_DISTANCE_PCT=3
WYCKOFF_MIN_CONFIDENCE=65
WYCKOFF_SL_BUFFER_PCT=0.5

# ICT / SMC strategy
SMC_AUTO_TIMEFRAMES=true
SMC_PREFERRED_RR=2
SMC_RELAXED_RR_TP=false
SMC_TAKE_PROFIT_ROI_PERCENT=30
SMC_MIN_SCORE=7
SMC_MAX_BARS_AFTER_SWEEP_FOR_MSS=10
SMC_FVG_MIN_SIZE_PCT=0.05
SMC_AVOID_MIDDLE_OF_RANGE=true
SMC_FVG_MAX_BARS_AFTER_MSS=3

# Indicators and leverage
SUPERTREND_PERIOD=10
SUPERTREND_MULTIPLIER=3
BOLLINGER_PERIOD=20
BOLLINGER_STD_DEV=2
SAR_STEP=0.02
SAR_MAX=0.2
LEVERAGE_MODE=fixed
FIXED_LEVERAGE=1
MIN_LEVERAGE=1
VOLATILITY_TIMEFRAME=1h
VOLATILITY_LOOKBACK=14
LOW_VOLATILITY_THRESHOLD=0.5
MEDIUM_VOLATILITY_THRESHOLD=1.5
HIGH_VOLATILITY_THRESHOLD=3
EXTREME_VOLATILITY_THRESHOLD=4
SKIP_TRADE_ON_EXTREME_VOLATILITY=true

# Optional AI service
AI_API_KEY=
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-5.5

# Local services
PORT=3001
SSE_HEARTBEAT_SECONDS=15
SQLITE_PATH=./data/trader.sqlite
LOG_LEVEL=info

# Optional Telegram signal delivery
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
PUBLIC_BASE_URL=http://127.0.0.1:3001
SIGNAL_CHART_DIR=./data/charts
